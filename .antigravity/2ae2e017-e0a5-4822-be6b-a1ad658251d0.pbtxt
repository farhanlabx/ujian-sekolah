          text: "    { x: 160, y: 160 },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    { x: 240, y: 170 },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    { x: 310, y: 165 }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  ];"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // Live Canvas Renderer"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  useEffect(() => {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    const canvas = canvasRef.current;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    if (!canvas) return;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    const ctx = canvas.getContext(\'2d\');"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    if (!ctx) return;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    // Clear Canvas"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    ctx.clearRect(0, 0, canvas.width, canvas.height);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    // Draw Grid Background"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    ctx.strokeStyle = \'#1e293b\';"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    ctx.lineWidth = 0.5;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    const gridSpacing = 20;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    for (let x = 0; x < canvas.width; x += gridSpacing) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      ctx.beginPath();"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      ctx.moveTo(x, 0);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      ctx.lineTo(x, canvas.height);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      ctx.stroke();"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    for (let y = 0; y < canvas.height; y += gridSpacing) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      ctx.beginPath();"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      ctx.moveTo(0, y);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      ctx.lineTo(canvas.width, y);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      ctx.stroke();"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    // Function to calculate curve height based on complexity setting"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    const getCurveY = (x: number): number => {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      // Base generalized path (Smooth cubic)"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      const baseCurve = 150 + 50 * Math.sin(x / 50) + 20 * Math.cos(x / 100);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      if (complexity < 25) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        // Underfitting: Degenerates to a flat straight line (linear)"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        const t = complexity / 25;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        const flatLine = 160 - (x - 200) * 0.1;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        return flatLine * (1 - t) + baseCurve * t;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      } else if (complexity > 70) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        // Overfitting: Extreme polynomial oscillation to try to hit all points"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        const t = (complexity - 70) / 30;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        const extremeOscillation = baseCurve + 60 * Math.sin(x / 9) * Math.sin(x / 14);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        return baseCurve * (1 - t) + extremeOscillation * t;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      // Balanced generalization"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      return baseCurve;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    };"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    // Draw Fitting Boundary Curve Line"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    ctx.beginPath();"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    ctx.lineWidth = 3;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    ctx.strokeStyle = complexity < 25 ? \'#F59E0B\' : complexity > 70 ? \'#EF4444\' : \'#00D4FF\';"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    ctx.shadowBlur = 10;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    ctx.shadowColor = ctx.strokeStyle;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    for (let x = 0; x <= canvas.width; x++) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      const y = getCurveY(x);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      if (x === 0) ctx.moveTo(x, y);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      else ctx.lineTo(x, y);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    ctx.stroke();"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    ctx.shadowBlur = 0; // reset shadow"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    // Draw training sets"
