    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "@import url(\'https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;700&display=swap\');\n@import \"tailwindcss\";\n\n@theme {\n  --font-sans: \"Inter\", ui-sans-serif, system-ui, sans-serif;\n  --font-display: \"Orbitron\", sans-serif;\n  --font-mono: \"JetBrains Mono\", ui-monospace, SFMono-Regular, monospace;\n\n  --color-bg-dark: #0A0E1A;\n  --color-bg-card: #111827;\n  --color-neon-blue: #00D4FF;\n  --color-neon-purple: #8B5CF6;\n  --color-neon-green: #10B981;\n  --color-neon-orange: #F59E0B;\n  --color-neon-red: #EF4444;\n\n  --animate-neon-pulse: neon-pulse 2s infinite alternate;\n  --animate-shimmer: shimmer 2.5s infinite linear;\n  --animate-float: float 4s ease-in-out infinite;\n  --animate-matrix: matrix 20s infinite linear;\n}\n\n@keyframes neon-pulse {\n  0% {\n    box-shadow: 0 0 4px rgba(0, 212, 255, 0.2), inset 0 0 4px rgba(0, 212, 255, 0.1);\n  }\n  100% {\n    box-shadow: 0 0 16px rgba(0, 212, 255, 0.6), inset 0 0 8px rgba(0, 212, 255, 0.3);\n  }\n}\n\n@keyframes shimmer {\n  0% {\n    background-position: -200% 0;\n  }\n  100% {\n    background-position: 200% 0;\n  }\n}\n\n@keyframes float {\n  0%, 100% {\n    transform: translateY(0);\n  }\n  50% {\n    transform: translateY(-8px);\n  }\n}\n\n@keyframes matrix {\n  0% {\n    background-position: 0% 0%;\n  }\n  100% {\n    background-position: 0% 100%;\n  }\n}\n\n/* Custom Scrollbars */\n::-webkit-scrollbar {\n  width: 6px;\n  height: 6px;\n}\n::-webkit-scrollbar-track {\n  background: #0A0E1A;\n}\n::-webkit-scrollbar-thumb {\n  background: #1e293b;\n  border-radius: 999px;\n}\n::-webkit-scrollbar-thumb:hover {\n  background: #8B5CF6;\n}\n\n/* Glassmorphism elements */\n.glass {\n  background: rgba(17, 24, 39, 0.75);\n  backdrop-filter: blur(12px);\n  -webkit-backdrop-filter: blur(12px);\n  border: 1px solid rgba(255, 255, 255, 0.05);\n}\n\n/* Electrical Spark Connection Animation helper */\n.spark-line {\n  stroke-dasharray: 8;\n  animation: spark 1s linear infinite;\n}\n\n@keyframes spark {\n  to {\n    stroke-dashoffset: -16;\n  }\n}\n\n/* Custom glow borders */\n.glow-blue:hover {\n  border-color: #00D4FF;\n  box-shadow: 0 0 15px rgba(0, 212, 255, 0.3);\n}\n\n.glow-purple:hover {\n  border-color: #8B5CF6;\n  box-shadow: 0 0 15px rgba(139, 92, 246, 0.3);\n}\n\n.glow-green:hover {\n  border-color: #10B981;\n  box-shadow: 0 0 15px rgba(16, 185, 129, 0.3);\n}\n\n.glow-orange:hover {\n  border-color: #F59E0B;\n  box-shadow: 0 0 15px rgba(245, 158, 11, 0.3);\n}\n\n.glow-red:hover {\n  border-color: #EF4444;\n  box-shadow: 0 0 15px rgba(239, 68, 68, 0.3);\n}\n\n/* CRT monitor lines overlay */\n.scanlines {\n  position: relative;\n  overflow: hidden;\n}\n.scanlines::before {\n  content: \" \";\n  display: block;\n  position: absolute;\n  top: 0; left: 0; bottom: 0; right: 0;\n  background: linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.25) 50%), linear-gradient(90deg, rgba(255, 0, 0, 0.06), rgba(0, 255, 0, 0.02), rgba(0, 0, 255, 0.06));\n  z-index: 10;\n  background-size: 100% 4px, 6px 100%;\n  pointer-events: none;\n}\n"
    }
